# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Monitoring / Alerts ─────────────────────────────────────────────────────
# Optional Discord webhook for scrape run alerts.
# When set, failures send alerts automatically.
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_ON_SUCCESS=true

# ─── Source target URLs ───────────────────────────────────────────────────────
# Comma-separated. Each source reads from <SOURCE_CONST>_URLS.

# Facebook Marketplace
# Run login once on a machine with a display:
#   npm run login -- --source facebook-marketplace
# Then copy cookies to your VPS:
#   scp storage/facebook-cookies.json root@VPS:/root/immoflow-scraper/storage/
FACEBOOK_MARKETPLACE_URLS=https://www.facebook.com/marketplace/115456095134627/propertyrentals?maxPrice=1700&sortBy=creation_time_descend&exact=false&latitude=46.5198&longitude=6.6335&radius=7&locale=fr_FR

# Facebook Groups
# Same login/cookie flow as Marketplace (shared facebook-cookies.json)
FACEBOOK_GROUPS_URLS=https://www.facebook.com/groups/173545046437954/?sorting_setting=CHRONOLOGICAL_LISTINGS&locale=fr_FR, https://www.facebook.com/groups/635474884461887/?sorting_setting=CHRONOLOGICAL&locale=fr_FR, https://www.facebook.com/groups/497095467395008/?sorting_setting=CHRONOLOGICAL&locale=fr_FR, https://www.facebook.com/groups/1604456726464086/?sorting_setting=CHRONOLOGICAL_LISTINGS&locale=fr_FR

