# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Source target URLs ───────────────────────────────────────────────────────
# Comma-separated. Each source reads from <SOURCE_CONST>_URLS.

# Facebook Marketplace
# Run login once on a machine with a display:
#   npm run login -- --source facebook-marketplace
# Then copy cookies to your VPS:
#   scp storage/facebook-cookies.json root@VPS:/root/immoflow-scraper/storage/
FACEBOOK_MARKETPLACE_URLS=https://www.facebook.com/marketplace/115456095134627/propertyrentals?maxPrice=1700&sortBy=creation_time_descend&exact=false&latitude=46.5198&longitude=6.6335&radius=7&locale=fr_FR

# Facebook Groups
# Same login/cookie flow as Marketplace (shared facebook-cookies.json)
FACEBOOK_GROUPS_URLS=https://www.facebook.com/groups/173545046437954/?sorting_setting=CHRONOLOGICAL_LISTINGS&locale=fr_FR, https://www.facebook.com/groups/635474884461887/?sorting_setting=CHRONOLOGICAL&locale=fr_FR, https://www.facebook.com/groups/497095467395008/?sorting_setting=CHRONOLOGICAL&locale=fr_FR, https://www.facebook.com/groups/1604456726464086/?sorting_setting=CHRONOLOGICAL_LISTINGS&locale=fr_FR

# Petitesannonces.ch
# Search results page for the target city and price range.
PETITES_ANNONCES_URLS=https://www.petitesannonces.ch/recherche/?tid=2701&ot=0&ri=0&ra=0&pi=&pa=1700&si=&sa=&zi=&ci=Lausanne&st=&cy=0

# immobilier.ch
# Lausanne rental search page.
IMMOBILIER_CH_URLS=https://www.immobilier.ch/fr/louer/appartement-maison/vaud/lausanne/page-1?t=rent&c=1;2&p=c11115&px=1700&nb=false&gr=1

# Room Estate
# Lausanne room-search page.
ROOM_ESTATE_URLS=https://roomestate.com/fr/room-search/Lausanne

# Régie Braun
# Lausanne rental listing page.
REGIE_BRAUN_URLS=https://www.regiebraun.ch/louer/

# Appartel
# Lausanne filtered search results.
APPARTEL_URLS=https://appartel.ch/annonces?ville=Lausanne&prixMax=2000&lat=46.520714&lng=6.632528

# Helvetia
# Lausanne Helvetia flat search. The source uses the Flatfox APIs behind the page.
HELVETIA_URLS=https://wohnung.helvetia.ch/fr/?east=6.720809&max_price=1750&north=46.591715&object_category=APARTMENT&object_category=HOUSE&object_category=SHARED&offer_type=RENT&place_name=Lausanne%2C%20canton%20de%20Vaud%2C%20Suisse&place_type=place&query=Lausanne&south=46.454875&west=6.560193

# Derham
# Lausanne filtered rentals.
DERHAM_URLS=https://www.derham.ch/fr/louer?field_geofield_proximity%5Bvalue%5D=0&field_geofield_proximity%5Bsource_configuration%5D%5Borigin_address%5D=Lausanne&field_property_type_target_id=17&field_total_price%5Bmin%5D=&field_total_price%5Bmax%5D=1750&field_part_number%5Bmin%5D=&field_part_number%5Bmax%5D=&field_living_area%5Bmin%5D=&field_living_area%5Bmax%5D=&sort_by=field_total_price_value_desc

# MyHomies
# Lausanne flatshare search results.
MYHOMIES_URLS=https://fr.myhomies.ch/discover/Lausanne-flatshare

# ─── Monitoring / Alerts ─────────────────────────────────────────────────────
# Optional Discord webhook for scrape run alerts.
# When set, failures send alerts automatically.
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_ON_SUCCESS=true
